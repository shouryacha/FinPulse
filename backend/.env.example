# Copy to .env for local development. On Render, set these as environment variables instead.

# Supabase (or any) Postgres connection string. Falls back to local SQLite if unset.
DATABASE_URL=postgresql://postgres:password@db.xxxxxxxx.supabase.co:5432/postgres

# How often (minutes) the background job re-pulls data from yfinance.
REFRESH_INTERVAL_MINUTES=15
